{
  "id": "nuvio35",
  "version": "1.2.0",
  "name": "MoOnCrOwN M3U",
  "description": "IPTV addon with M3U for Nuvio",
  "logo": "https://i.imgur.com/Dlsm9XP.png",
  "resources": [
    "catalog",
    "stream",
    "meta"
  ],
  "types": [
    "tv",
    "movie"
  ],
  "catalogs": [
    {
      "type": "tv",
      "id": "nv_channels",
      "name": "MoOnCrOwN TV Kanalları",
      "extra": [
        { "name": "genre" },
        { "name": "search" },
        { "name": "skip" }
      ],
      "genres": [
        "ULUSAL KANALLAR",
        "SPOR KANALLARI",
        "HABER KANALLARI",
        "SİNEMA KANALLARI",
        "Genel"
      ]
    },
    {
      "type": "movie",
      "id": "nv_movies",
      "name": "MoOnCrOwN Filmler",
      "extra": [
        { "name": "search" },
        { "name": "skip" }
      ]
    }
  ],
  "idPrefixes": [
    "nv_"
  ],
  "scrapers": [
    {
      "id": "mc_scraper",
      "name": "MC Engine",
      "filename": "m3u.js",
      "enabled": true,
      "types": ["tv", "movie"],
      "resources": ["catalog", "meta", "stream"]
    }
  ],
  "behaviorHints": {
    "configurable": true,
    "configurationRequired": false
  }
}
